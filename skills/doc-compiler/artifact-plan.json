{
  "template": "default-docs-v1",
  "template_version": "v1",
  "page_structure": {
    "sections": [
      {
        "section_id": "overview",
        "template": "section-hero",
        "data_keys": [
          "name",
          "version",
          "description"
        ],
        "required": true,
        "render": true
      },
      {
        "section_id": "diagram",
        "template": "section-mermaid",
        "data_keys": [
          "diagram_plan_id"
        ],
        "required": true,
        "render": true
      },
      {
        "section_id": "steps",
        "template": "section-accordion",
        "data_keys": [
          "steps"
        ],
        "required": true,
        "render": true
      },
      {
        "section_id": "proof",
        "template": "section-proof",
        "data_keys": [],
        "required": true,
        "render": true
      }
    ]
  },
  "ui_config": {
    "palette": "tailwind-modern",
    "toc_width": "18rem",
    "toc_breakpoint": 960,
    "diagram_height_initial": 480,
    "diagram_height_min": 200,
    "diagram_height_max": 800
  },
  "mermaid_source": "",
